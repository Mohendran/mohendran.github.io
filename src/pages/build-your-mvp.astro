---
import Button from "../components/button.astro";
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";

---

<Layout title="Build Your MVP in 30 Days | SaaS | Quick Market Validation | Product Market Fit">
  <div
    class="relative z-20 w-full max-w-4xl mx-auto mt-8 px-7 xl:px-0 min-h-[calc(100vh-278px)] md:min-h-[calc(100vh-288px)]"
  >
    <div class="flex flex-col items-center md:flex-row">
      <div class="relative w-full md:w-1/2">
        <h1
          class="mb-5 text-5xl font-bold leading-tight md:text-4xl lg:text-5xl dark:text-white"
        >
          <span class="text-2xl">Start building the next</span><br/>
          <span class="relative inline-block">
            <span
              id="dynamic-text"
              class="text-orange-500 transition-opacity duration-700"
            >
            Zendesk
            </span>
          </span>
        </h1>
        <script>
          const words = ["Zendesk", "Shopify", "TikTok", "Intercom", "Hubspot", "Facebook"];
          const intervalTime = 2000;
          let currentWordIndex = 0;
        
          const dynamicTextElement = document.getElementById("dynamic-text");
        
          setInterval(() => {
            // Update the word
            currentWordIndex = (currentWordIndex + 1) % words.length;
        
            // Add fade-out effect
            dynamicTextElement.classList.add("opacity-0");
            setTimeout(() => {
              // Update text and fade-in
              dynamicTextElement.textContent = words[currentWordIndex];
              dynamicTextElement.classList.remove("opacity-0");
            }, 600);
          }, intervalTime);
        </script>
        <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
          Hi, I’m Mohendran, a seasoned SaaS developer based in Chennai, India, with over 8 years of experience crafting amazing SaaS apps that help businesses scale and succeed.
         <br
            class="hidden lg:block"
          />
        </p>
        <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
          Whether you're just getting started with an idea or need to take your SaaS product to the next level, I can help you bring your vision to life.
          <br
            class="hidden lg:block"
          />
        </p>
        <p class="mb-2 font-semibold text-neutral-800 dark:text-neutral-200">
          I can help you out with:
        </p>
        <ul
          class="py-2 space-y-[3px] text-sm list-disc list-inside text-neutral-500 dark:text-neutral-400"
        > 
          <li>Building MVPs in 30 days</li>
          <li>Quick Market Validation</li>
          <li>Building AI Products</li>
          <li>Achieve Product Market Fit</li>
          <li>and more...</li>
        </ul>
        <Button text="Contact me via Email" link="mailto:mohendran@sparker.tech" />
      </div>
      <div
        class=" justify-end hidden w-full mt-10 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0"
      >
            <img
              src="https://www.bespokesoftwaredevelopment.com/blog/wp-content/uploads/2023/01/software-development-company2.jpg"
              loading="eager"
              decoding="auto"
              class="relative z-30 w-full md:max-w-md mx-auto dark:-translate-y-0.5 object-contain rounded-2xl"
            />
      </div>
    </div>
  </div>
</Layout>
