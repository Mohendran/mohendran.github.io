---
import Button from "../components/button.astro";
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Mohendran | Front-end Developer | India">
  <div
    class="relative z-20 w-full max-w-4xl mx-auto  md:mt-8 px-7 xl:px-0 min-h-[calc(100vh-250px)] md:min-h-[calc(100vh-288px)]"
  >
    <div class="flex flex-col-reverse items-center md:flex-row">
      <div class="relative mt-8 md:mt-auto w-full md:w-1/2">
        <h1
          class="mb-5 text-4xl font-bold leading-tight md:text-4xl lg:text-5xl dark:text-white"
        >
          <span class="text-2xl">Let AI Review your </span> <br/><span class="text-orange-500">Medium Drafts</span>
        </h1>
        <p class="mb-4 text-base text-neutral-600 dark:text-neutral-400">
          Traditionally, writers shared their drafts with friends, peers, or mentors to get feedback and improve their work. While this process is valuable, it can be time-consuming and often slows down the creative flow.
        </p>
        <p class="mb-4 text-base text-neutral-600 dark:text-neutral-400">
          Now, with just one click, AI can provide instant suggestions and make the process faster and easier
        </p>
        <form method="POST" id="form" class="relative z-30 w-full md:max-w-md mx-auto dark:-translate-y-0.5 space-y-6">
          <input type="hidden" name="access_key" value="6a4e2d9d-9d1e-4185-8f73-7ea2ad6bf3f4">
      
          <div class="flex flex-col space-y-1">
            <label for="email" class="text-md font-semibold text-gray-700">Get access for free!</label>
            <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="Enter your email" 
                required 
                class="mt-1 p-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
            />
          </div>
          <!-- Honeypot Spam Protection -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
      
      
           <div class="flex justify-center items-center align-middle w-full">
             <button id="form-submit" type="submit" class="py-2 px-4 text-sm font-semibold duration-300 ease-out border rounded-full bg-neutral-900 dark:bg-white dark:text-neutral-900 text-neutral-100 hover:border-neutral-700 border-neutral-900 dark:hover:border-neutral-300 hover:bg-white dark:hover:bg-black dark:hover:text-white hover:text-neutral-900">
              Join the Waitlist
             </button>
           </div>
          </form>
          <div id="result" class="text-center text-md text-gray-600 mt-4 font-semibold mb-8 md:mb-auto"></div>
      <script is:inline>
      const form = document.getElementById('form');
      const result = document.getElementById('result');
      
      form.addEventListener('submit', function (e) {
          const formData = new FormData(form);
          e.preventDefault();
      
          const object = Object.fromEntries(formData);
          const json = JSON.stringify(object);
          const submitBtn = document.getElementById('form-submit');
      
          submitBtn.innerText = "Please wait...";
          submitBtn.disabled = true;
      
          fetch('https://api.web3forms.com/submit', {
                  method: 'POST',
                  headers: {
                      'Content-Type': 'application/json',
                      'Accept': 'application/json'
                  },
                  body: json
              })
              .then(async (response) => {
                  let json = await response.json();
                  if (response.status == 200) {
                      result.innerHTML = `<span class="text-green-500">You have joined the waitlist!</span>`;
                      form.style.display = 'none';
                  } else {
                      console.log(response);
                      submitBtn.innerText = "Join the Waitlist";
                      submitBtn.disabled = false;
                      result.innerHTML = `<span class="text-red-500">Something went wrong!</span>`;
                  }
              })
              .catch(error => {
                  console.log(error);
                  submitBtn.innerText = "Join the Waitlist";
                  submitBtn.disabled = false;
                  result.innerHTML = `<span class="text-red-500">Something went wrong!</span>`;
                  form.reset();
                  setTimeout(() => {
                      result.innerHTML = "";
                  }, 3000);
              })
      });
      </script>
      </div>
      <div
      class="relative justify-end w-full mt-10 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0"
    >
      <div class="relative z-50 w-full">
        <div
          class="absolute -bottom-24 z-40 w-16 h-16 -translate-x-6 -translate-y-1/2 lg:top-auto top-0 lg:-translate-y-[330px] rounded-full"
        >
          <span
            class="relative z-20 flex items-center justify-center w-full h-full text-2xl border-8 border-white rounded-full dark:border-neutral-950 bg-neutral-100 dark:bg-neutral-900"
          >
            <span
              class="flex items-center justify-center w-full h-full bg-white border border-dashed rounded-full dark:bg-neutral-950 border-neutral-300 dark:border-neutral-700"
              >👋</span
            >
          </span>
        </div>

        <div
          class=" bottom-0 right-0 z-20 w-full translate-x-0 -translate-y-px border border-dashed rounded-2xl bg-gradient-to-r dark:from-neutral-950 dark:via-black dark:to-neutral-950 from-white via-neutral-50 to-white border-neutral-300 dark:border-neutral-700"
        >
        <div class=" z-30 px-5 py-5">
          <img
            src="/assets/images/robot-review.jpg"
            loading="eager"
            decoding="auto"
            class=" z-30 w-full aspect-square md:max-w-md mx-auto dark:-translate-y-0.5 rounded-2xl"
          />
        </div>
        </div>
      </div>
    </div>
    </div>
  </div>
</Layout>
