---
import Button from "../components/button.astro";
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import experiences from "../collections/experiences.json";

import Layout from "../layouts/main.astro";
import AboutExperience from "../components/about-experience.astro";
---

<Layout title="SaaS Developer for Hire | Next.js Developer | React | Angular | FrontEnd">
  <div
    class="relative z-20 w-full max-w-4xl mx-auto mt-8 px-7 xl:px-0"
  >
    <div class="flex flex-col items-center md:flex-row">
      <div class="relative w-full md:w-1/2">
        <h1
          class="mb-5 text-4xl font-bold leading-tight md:text-4xl lg:text-5xl dark:text-white"
        >
          <span class="text-2xl">Are you looking for a</span> <br/><span id="dynamic-text" class="text-orange-500 transition-opacity duration-700"
          >SaaS Developer ?</span>
        </h1>
        <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
          Hi, I’m Mohendran, a seasoned SaaS developer based in Chennai, India, with over 8 years of experience crafting amazing SaaS apps that help businesses scale and succeed.
        <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
            I've helped companies launch over 50+ MVPs and SaaS products, including Chatbots, CRMs, Social Media Platforms, and E-Commerce solutions.
        </p>
        <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
          I bring your product ideas to life, letting you focus entirely on your business while I handle the tech.
        </p>
        <p class="mb-2 font-semibold text-neutral-800 dark:text-neutral-200">
          I can help you out with:
        </p>
        <ul
          class="py-2 space-y-[3px] text-sm list-disc list-inside text-neutral-500 dark:text-neutral-400"
        > 
          <li>Building First-Class SaaS Products</li>
          <li>Building MVPs in 30 days</li>
          <li>Offshore Development</li>
          <li>FrontEnd Development</li>
          <li>and more...</li>
        </ul>
        <Button text="Contact me on LinkedIn" link="https://www.linkedin.com/in/mohendran/" />
      </div>
      <div
        class="relative justify-end hidden w-full mt-10 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0"
      >
        <div class="relative z-50 w-full">
          <div
            class="absolute -bottom-24 z-40 w-16 h-16 -translate-x-6 -translate-y-1/2 lg:top-auto top-0 lg:-translate-y-[330px] rounded-full"
          >
            <span
              class="relative z-20 flex items-center justify-center w-full h-full text-2xl border-8 border-white rounded-full dark:border-neutral-950 bg-neutral-100 dark:bg-neutral-900"
            >
              <span
                class="flex items-center justify-center w-full h-full bg-white border border-dashed rounded-full dark:bg-neutral-950 border-neutral-300 dark:border-neutral-700"
                >👋</span
              >
            </span>
          </div>
          <div class="relative z-30 px-10">
            <img
              src="/assets/images/photo.png"
              loading="eager"
              decoding="auto"
              class="relative z-30 w-full aspect-square md:max-w-md mx-auto dark:-translate-y-0.5"
            />
          </div>
          <div
            class="absolute bottom-0 right-0 z-20 w-full h-full lg:h-[370px] translate-x-0 -translate-y-px border border-dashed rounded-2xl bg-gradient-to-r dark:from-neutral-950 dark:via-black dark:to-neutral-950 from-white via-neutral-50 to-white border-neutral-300 dark:border-neutral-700"
          >
          </div>
        </div>
      </div>
    </div>
  </div>

  <Separator text="Check out my projects" />
  <Projects />
  <Separator text="My Experience" />
  <!-- <Writings /> -->
  <section class="max-w-4xl mx-auto px-7 lg:px-0">

      <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experience
    </h2>
    <div class="px-5 -mb-10">
      {
        experiences.map((experience) => {
          return (
            <div class="pb-10 border-l border-gray-200 last:border-l-0 dark:border-neutral-700">
              <AboutExperience
                dates={experience.dates}
                role={experience.role}
                company={experience.company}
                description={experience.description}
                logo={experience.logo}
              />
            </div>
          )
        })
      }
    </div>
  </section>
  <Separator text="My Blog Posts" />
  <Writings />
</Layout>

<script>
  const words = ["SaaS Developer ?", "MVP in 30 Days ?", "Full Stack Dev ?", "Next.js Developer ?", "React Developer ?", "Angular Architect ?"];
  const intervalTime = 2000;
  let currentWordIndex = 0;

  const dynamicTextElement = document.getElementById("dynamic-text");

  setInterval(() => {
    // Update the word
    currentWordIndex = (currentWordIndex + 1) % words.length;

    // Add fade-out effect
    dynamicTextElement.classList.add("opacity-0");
    setTimeout(() => {
      // Update text and fade-in
      dynamicTextElement.textContent = words[currentWordIndex];
      dynamicTextElement.classList.remove("opacity-0");
    }, 600);
  }, intervalTime);
</script>